#!/bin/bash
# Apply Omarchy theme colors to delta (git diff pager)

set -euo pipefail

OMARCHY_THEMES_DIR="$HOME/.local/share/omarchy/themes"
OMARCHY_CURRENT_THEME="$HOME/.config/omarchy/current/theme"
DELTA_THEMES_DIR="$HOME/.config/delta/themes"
DELTA_THEME_FILE="$DELTA_THEMES_DIR/omarchy.gitconfig"

log_info() {
  echo "[INFO] $*"
}

log_success() {
  echo "[SUCCESS] $*"
}

log_error() {
  echo "[ERROR] $*" >&2
}

# Color manipulation functions
hex_to_rgb() {
  local hex="$1"
  hex="${hex#\#}"
  local r=$((16#${hex:0:2}))
  local g=$((16#${hex:2:2}))
  local b=$((16#${hex:4:2}))
  echo "$r $g $b"
}

rgb_to_hex() {
  local r="$1" g="$2" b="$3"
  printf "#%02x%02x%02x" "$r" "$g" "$b"
}

lighten_color() {
  local hex="$1"
  local factor="${2:-20}"
  
  read -r r g b <<< "$(hex_to_rgb "$hex")"
  
  r=$(( r + (255 - r) * factor / 100 ))
  g=$(( g + (255 - g) * factor / 100 ))
  b=$(( b + (255 - b) * factor / 100 ))
  
  r=$((r > 255 ? 255 : r))
  g=$((g > 255 ? 255 : g))
  b=$((b > 255 ? 255 : b))
  
  rgb_to_hex "$r" "$g" "$b"
}

darken_color() {
  local hex="$1"
  local factor="${2:-20}"
  
  read -r r g b <<< "$(hex_to_rgb "$hex")"
  
  local multiplier=$((100 - factor))
  r=$((r * multiplier / 100))
  g=$((g * multiplier / 100))
  b=$((b * multiplier / 100))
  
  r=$((r < 0 ? 0 : r))
  g=$((g < 0 ? 0 : g))
  b=$((b < 0 ? 0 : b))
  
  rgb_to_hex "$r" "$g" "$b"
}

apply_alpha() {
  local hex="$1"
  local alpha_percent="$2"
  local alpha=$((255 * alpha_percent / 100))
  printf "%s%02x" "$hex" "$alpha"
}

# Get theme name from argument or current theme
get_theme_name() {
  if [[ -n "${1:-}" ]]; then
    echo "$1"
    return
  fi
  
  local theme_name_file="$HOME/.config/omarchy/current/theme.name"
  if [[ -f "$theme_name_file" ]]; then
    cat "$theme_name_file"
    return
  fi
  
  if [[ -L "$OMARCHY_CURRENT_THEME" ]]; then
    basename "$(readlink "$OMARCHY_CURRENT_THEME")"
    return
  fi
  
  echo "catppuccin"
}

validate_colors() {
  local required=(background foreground color1 color2 color3 color4 color5 accent)
  local key

  for key in "${required[@]}"; do
    if [[ -z "${COLORS[$key]:-}" ]]; then
      log_error "Missing required color '$key'"
      exit 1
    fi
  done
}

parse_colors_toml() {
  local colors_file="$1"

  declare -gA COLORS
  while IFS='=' read -r key value; do
    key="${key//[\"\' ]/}"
    [[ $key && $key != \#* ]] || continue
    value="${value#*[\"\']}"
    value="${value%%[\"\']*}"
    COLORS["$key"]="$value"
  done < "$colors_file"

  validate_colors
}

parse_alacritty_toml() {
  local alacritty_file="$1"
  local section=""

  declare -gA COLORS
  while IFS= read -r line; do
    if [[ $line =~ ^[[:space:]]*\[(.+)\][[:space:]]*$ ]]; then
      section="${BASH_REMATCH[1]}"
      continue
    fi

    if [[ $line =~ ^[[:space:]]*([a-zA-Z_]+)[[:space:]]*=[[:space:]]*\"(#[0-9A-Fa-f]{6})\"[[:space:]]*$ ]]; then
      local key="${BASH_REMATCH[1]}"
      local value="${BASH_REMATCH[2]}"
      case "$section.$key" in
        colors.primary.background) COLORS[background]="$value" ;;
        colors.primary.foreground) COLORS[foreground]="$value" ;;
        colors.normal.red) COLORS[color1]="$value" ;;
        colors.normal.green) COLORS[color2]="$value" ;;
        colors.normal.yellow) COLORS[color3]="$value" ;;
        colors.normal.blue)
          COLORS[color4]="$value"
          COLORS[accent]="$value"
          ;;
        colors.normal.magenta) COLORS[color5]="$value" ;;
      esac
    fi
  done < "$alacritty_file"

  if [[ -z "${COLORS[accent]:-}" && -n "${COLORS[color4]:-}" ]]; then
    COLORS[accent]="${COLORS[color4]}"
  fi

  validate_colors
}

# Parse colors with colors.toml first, then alacritty.toml fallback
parse_colors() {
  local theme_name="$1"

  local theme_colors="$OMARCHY_THEMES_DIR/$theme_name/colors.toml"
  local current_colors="$HOME/.config/omarchy/current/theme/colors.toml"
  local theme_alacritty="$OMARCHY_THEMES_DIR/$theme_name/alacritty.toml"
  local current_alacritty="$HOME/.config/omarchy/current/theme/alacritty.toml"

  if [[ -f "$theme_colors" ]]; then
    log_info "Using colors.toml from theme directory"
    parse_colors_toml "$theme_colors"
    return
  fi

  if [[ -f "$current_colors" ]]; then
    log_info "Using colors.toml from current theme"
    parse_colors_toml "$current_colors"
    return
  fi

  if [[ -f "$theme_alacritty" ]]; then
    log_info "colors.toml missing; falling back to theme alacritty.toml"
    parse_alacritty_toml "$theme_alacritty"
    return
  fi

  if [[ -f "$current_alacritty" ]]; then
    log_info "colors.toml missing; falling back to current alacritty.toml"
    parse_alacritty_toml "$current_alacritty"
    return
  fi

  log_error "No colors.toml or alacritty.toml found for theme: $theme_name"
  exit 1
}

# Generate delta theme config
generate_delta_theme() {
  local bg="${COLORS[background]}"
  local fg="${COLORS[foreground]}"
  local color1="${COLORS[color1]}"
  local color2="${COLORS[color2]}"
  local color3="${COLORS[color3]}"
  local color4="${COLORS[color4]}"
  local color5="${COLORS[color5]}"
  local accent="${COLORS[accent]}"
  
  # Determine if light or dark theme
  bg_r=$((16#${bg:1:2}))
  bg_g=$((16#${bg:3:2}))
  bg_b=$((16#${bg:5:2}))
  bg_brightness=$((bg_r + bg_g + bg_b))
  
  local is_light="false"
  if [[ $bg_brightness -gt 382 ]]; then
    is_light="true"
  fi
  
  # Generate colors for minus/plus - use foreground colors only, no background
  local minus_fg plus_fg minus_fg_emph plus_fg_emph zero_fg
  local file_style hunk_style
  
  if [[ "$is_light" == "true" ]]; then
    # Light theme - use darker foreground colors
    minus_fg=$(darken_color "$color1" 20)
    plus_fg=$(darken_color "$color2" 20)
    minus_fg_emph="$color1"
    plus_fg_emph="$color2"
    zero_fg=$(darken_color "$fg" 30)
    file_style="$accent"
    hunk_style="$color3"
  else
    # Dark theme - use foreground colors directly
    minus_fg=$(lighten_color "$color1" 10)
    plus_fg=$(lighten_color "$color2" 10)
    minus_fg_emph="$color1"
    plus_fg_emph="$color2"
    zero_fg="$fg"
    file_style="$accent"
    hunk_style="$color3"
  fi
  
  # Generate blame palette (3 variations of background)
  local blame1 blame2 blame3
  if [[ "$is_light" == "true" ]]; then
    blame1=$(darken_color "$bg" 3)
    blame2=$(darken_color "$bg" 6)
    blame3=$(darken_color "$bg" 9)
  else
    blame1=$(lighten_color "$bg" 3)
    blame2=$(lighten_color "$bg" 6)
    blame3=$(lighten_color "$bg" 9)
  fi
  
  # Generate config
  cat > "$DELTA_THEME_FILE" << EOF
# Delta theme generated from Omarchy theme
# Do not edit manually - this file is auto-generated

[delta]
    # Diff colors - foreground only, no background fill
    minus-style = "$minus_fg"
    minus-emph-style = "$minus_fg_emph bold"
    minus-non-emph-style = "$minus_fg"
    
    plus-style = "$plus_fg"
    plus-emph-style = "$plus_fg_emph bold"
    plus-non-emph-style = "$plus_fg"
    
    zero-style = "$zero_fg"
    
    # UI colors
    file-style = "$file_style"
    hunk-header-style = "$hunk_style"
    grep-file-style = "$color5"
    grep-line-number-style = "$color3"
    
    # Blame
    blame-palette = "$blame1 $blame2 $blame3"
    
    # Settings
    true-color = always
EOF
  
  log_success "Generated delta theme: $DELTA_THEME_FILE"
}

# Ensure include is in gitconfig
ensure_gitconfig_include() {
  local gitconfig="$HOME/.gitconfig"
  local include_line="[include]"
  local path_line="    path = $DELTA_THEME_FILE"
  
  # Create gitconfig if it doesn't exist
  if [[ ! -f "$gitconfig" ]]; then
    touch "$gitconfig"
  fi
  
  # Check if include already exists
  if grep -qF "$DELTA_THEME_FILE" "$gitconfig" 2>/dev/null; then
    log_info "Include already present in gitconfig"
    return 0
  fi
  
  # Add include section
  {
    echo ""
    echo "# >>> omarchy-delta-theme-sync >>>"
    echo "$include_line"
    echo "$path_line"
    echo "# <<< omarchy-delta-theme-sync <<<"
  } >> "$gitconfig"
  
  log_success "Added include to gitconfig"
}

# Main
main() {
  local theme_name
  theme_name=$(get_theme_name "$@")
  
  log_info "Applying Omarchy theme to delta: $theme_name"
  
  mkdir -p "$DELTA_THEMES_DIR"
  
  parse_colors "$theme_name"
  generate_delta_theme
  ensure_gitconfig_include
  
  log_success "Delta theme applied successfully"
}

main "$@"
